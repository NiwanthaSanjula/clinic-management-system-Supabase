// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Role enum - only two possible values for staff
// Patient role is handled separately (they logged in via portal, no staff system)
enum Role {
  DOCTOR
  ASSISTANT
  PATIENT
}

// Profile table - extends Supabase's built-in auth.users table
// When a stafff member signs up, we create a Profile row
// The id here MATCHES the id in Supabase Auth exactly
model Profile {
  id        String   @id
  role      Role
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient? // only exists if role is PATIENT

  @@map("profiles") // actual table name in supabase db
}

// AuditLog - track every important action in clinic
// Built now so every future features can use it from the start
model AuditLog {
  id         String   @id @default(cuid())
  userId     String // Who did the action
  action     String // e.g. "CREATE_PATIENT", "UPDATE_APPOINTMENT"
  entityType String // e.g. "Patient", "Appointment"
  entityId   String // the ID of the thing that changed
  oldValue   Json? // what it looked like before(optional)
  newValue   Json? // what it looks like now(optional)
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

// Patient - people who visit the clinic
// They can also have a portal account (patientAuthId links to Supabase auth)
model Patient {
  id             String        @id @default(cuid())
  profile        Profile       @relation(fields: [id], references: [id])
  nic            String        @unique
  dateOfBirth    DateTime?
  gender         String?
  phone          String
  email          String?
  address        String?
  bloodGroup     String?
  knownAllergies String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  vitals         Vitals[]
  appointments   Appointment[]

  @@map("patients")
}

model Vitals {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id])
  recordedBy    String // Assistant's profile id
  bloodPressure String? // e.g. "120/80"
  weight        Float? //kg
  temperature   Float? // Celsius
  pulse         Int? // bpm
  notes         String?
  recordedAt    DateTime @default(now())

  @@map("vitals")
}

// Appointment status flow:
// SCHEDULED -> WAITING -> IN_CONSULTATION -> COMPLETED
//           -> CANCELLED (form any status)
enum AppointmentStatus {
  SCHEDULED
  WAITING
  IN_CONSULTATION
  COMPLETED
  CANCELLED
}

enum AppointmentType {
  BOOKED // has a time slot
  WALKIN // no slot - added to queue directly
}

// Clinic working hours and slot configuration
// Only ONE row ever exists - updated by doctor
model ClinicSettings {
  id           String @id @default(cuid())
  openTime     String @default("09:00")
  closeTime    String @default("17:00")
  slotDuration Int    @default(20)
  lunchStart   String @default("13:00")
  lunchEnd     String @default("13:30")
  clinicName   String @default("My Clinic")
  consultFee   Float  @default(1000)

  @@map("clinic_settings")
}

// One row per appointment
model Appointment {
  id        String            @id @default(cuid())
  patientId String
  patient   Patient           @relation(fields: [patientId], references: [id])
  date      String // "2026-05-01" -stored as string for simplicity
  timeSlot  String? // "09:00" - null for walk-ins
  type      AppointmentType   @default(BOOKED)
  status    AppointmentStatus @default(SCHEDULED)
  notes     String? // booking notes 
  createdBy String // profile id of who booked
  createdAt DateTime          @default(now())
  updateAt  DateTime          @updatedAt

  // Prevent double bookings - same data + same slot = error
  @@unique([date, timeSlot])
  @@map("appointments")
}
